{
  "name": "brevity-workflow-vite",
  "version": "2.0.0",
  "author": "Atlas",
  "license": "MIT",
  "homepage": "https://github.com/owler11/Brevity-Vite/upload",
  "description": "Modern Vite workflow for WordPress front-end development and testing (plugins & themes) with handy tools included.",
  "main": "vite.config.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "scripts": {
    "dev": "rimraf assets/public/manifest.json && vite",
    "dev:open": "vite --open",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "prod": "npm run build",
    "prod:watch": "npm run build:watch",
    "lint:js": "eslint assets/src/js/**/*.js",
    "lint:js:fix": "eslint assets/src/js/**/*.js --fix",
    "lint:css": "stylelint 'assets/src/**/**/*.{css,scss,sass,pcss}' '!assets/src/sass/fontawesome-pro/*' '!assets/src/sass/plugin/**/*' --config config/.stylelintrc.cjs",
    "lint:css:fix": "stylelint 'assets/src/**/**/*.{css,scss,sass,pcss}' '!assets/src/sass/fontawesome-pro/*' '!assets/src/sass/plugin/**/*' --config config/.stylelintrc.cjs --fix",
    "format": "prettier assets/src/js/**/*.js --write",
    "format:check": "prettier assets/src/js/**/*.js --check",
    "translate": "wp-pot --src '**/**/**/*.php' --dest-file 'languages/wordpress-vite.pot' --package 'Atlas' --domain 'atlas' --last-translator 'Atlas' --team 'Atlas' --bug-report ''",
    "clean": "rimraf assets/public/*",
    "analyze": "vite-bundle-analyzer",
    "add:acf-block": "node scripts/add-block.js",
    "add:new-acf-block": "node scripts/add-new-block.js"
  },
  "dependencies": {
    "gsap": "^3.12.2",
    "jquery": "^3.7.1",
    "magnific-popup": "^1.1.0",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-legacy": "^5.4.3",
    "@wordpress/eslint-plugin": "^17.13.0",
    "autoprefixer": "^10.4.15",
    "baseline-browser-mapping": "^2.10.10",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "inquirer": "^13.1.0",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.1",
    "sass": "^1.93.2",
    "sass-glob-importer": "^1.0.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.12.1",
    "terser": "^5.44.0",
    "vite": "^5.0.0",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-static-copy": "^0.17.0",
    "vite-plugin-stylelint": "^6.0.2",
    "wp-pot-cli": "^1.5.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "keywords": [
    "wordpress",
    "workflow",
    "vite",
    "theme",
    "plugin",
    "Vite",
    "Autoprefixer",
    "ESLint",
    "Stylelint",
    "SCSS",
    "WP-Pot",
    "HMR"
  ]
}
